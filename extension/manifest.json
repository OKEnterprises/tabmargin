{
  "manifest_version": 2,
  "name": "TabMargin",
  "version": "2.0.0",
  "description": "Turn your new tab page into a minimalist notepad with persistent storage",

  "icons": {
    "48": "icons/notes.svg",
    "96": "icons/notes.svg"
  },

  "browser_action": {
    "default_icon": {
      "48": "icons/notes.svg",
      "96": "icons/notes.svg"
    },
    "default_title": "TabMargin Settings",
    "default_popup": "popup.html"
  },

  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },

  "permissions": [
    "storage",
    "https://api.tabmargin.com/*",
    "https://*.supabase.co/*"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "notetab@example.com",
      "strict_min_version": "58.0"
    }
  }
}
